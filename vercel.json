{
  "buildCommand": "",
  "outputDirectory": ".",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- index.html assets/",
  "headers": [
    {
      "source": "/assets/video/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
